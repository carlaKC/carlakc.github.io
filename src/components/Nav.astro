---
// Root-relative fragments so nav works from post pages too (not just '/').
const links = [
  { href: '/#about', label: 'About' },
  { href: '/#working-on', label: 'Working on' },
  { href: '/#writing', label: 'Writing' },
  { href: '/#appearances', label: 'Appearances' },
];
---
<header class="site-header">
  <div class="inner">
    <a href="/" class="wordmark">CKC</a>
    <nav>
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--hairline);
  }
  /* header sits over the artwork; keep it transparent */
  .inner {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 1.5rem 1.5rem 1.25rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem 2rem;
    flex-wrap: wrap;
  }
  .wordmark {
    color: var(--ink);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.22em;
  }
  .wordmark:hover { color: var(--terracotta); text-decoration: none; }
  nav {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  nav a {
    color: #4a4038;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
  }
  nav a:hover { color: var(--terracotta); text-decoration: none; }

  @media (max-width: 34rem) {
    nav { gap: 1rem; }
    nav a { font-size: 0.78rem; }
  }
</style>
