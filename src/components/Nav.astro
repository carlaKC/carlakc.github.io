---
import ThemeToggle from './ThemeToggle.astro';
// Root-relative fragments so nav works from post pages too (not just '/').
const links = [
  { href: '/#about', label: 'about' },
  { href: '/#working-on', label: 'working on' },
  { href: '/#writing', label: 'writing' },
  { href: '/#appearances', label: 'appearances' },
];
---
<header class="nav">
  <a href="/" class="brand mono">carla</a>
  <nav>
    {links.map((l) => <a href={l.href} class="mono">{l.label}</a>)}
  </nav>
  <ThemeToggle />
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--border);
  }
  .brand { color: var(--heading); font-weight: 600; }
  nav { display: flex; gap: 1rem; flex-wrap: wrap; margin-right: auto; }
  nav a { color: var(--text); font-size: 0.9rem; }
  nav a:hover { color: var(--accent); text-decoration: none; }
  @media (max-width: 30rem) {
    .brand { display: none; }
    nav { font-size: 0.8rem; }
  }
</style>
